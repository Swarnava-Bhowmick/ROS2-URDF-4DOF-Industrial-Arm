<?xml version="1.0" ?>
<robot name="four_dof_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="grey">  <color rgba="0.4 0.4 0.4 1.0"/> </material>
  <material name="blue">  <color rgba="0.1 0.3 0.8 1.0"/> </material>
  <material name="green"> <color rgba="0.1 0.7 0.2 1.0"/> </material>
  <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/> </material>
  <material name="red">   <color rgba="0.8 0.1 0.1 1.0"/> </material>

  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry><box size="0.5 0.5 0.2"/></geometry>
      <material name="grey"/>
    </visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0.1"/><geometry><box size="0.5 0.5 0.2"/></geometry></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.04"/></inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-3.14" upper="3.14" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 0.2"/>
    <parent link="base_link"/><child link="link_01"/>
  </joint>

  <link name="link_01">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.2"/>
      <geometry><cylinder radius="0.1" length="0.4"/></geometry>
      <material name="blue"/>
    </visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0.2"/><geometry><cylinder radius="0.1" length="0.4"/></geometry></collision>
    <inertial><mass value="1.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.005"/></inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 0.4"/>
    <parent link="link_01"/><child link="link_02"/>
  </joint>

  <link name="link_02">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.25"/>
      <geometry><cylinder radius="0.07" length="0.5"/></geometry>
      <material name="green"/>
    </visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0.25"/><geometry><cylinder radius="0.07" length="0.5"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.003"/></inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 0.5"/>
    <parent link="link_02"/><child link="link_03"/>
  </joint>

  <link name="link_03">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
      <material name="orange"/>
    </visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0.2"/><geometry><cylinder radius="0.05" length="0.4"/></geometry></collision>
    <inertial><mass value="0.7"/><inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.001"/></inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0 0 0.4"/>
    <parent link="link_03"/><child link="end_effector"/>
  </joint>

  <link name="end_effector">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry><box size="0.08 0.08 0.1"/></geometry>
      <material name="red"/>
    </visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0.05"/><geometry><box size="0.08 0.08 0.1"/></geometry></collision>
    <inertial><mass value="0.3"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

</robot>